  "welcome_tryTitle": { "message": "ನಿಮ್ಮ ಮೊದಲ ರೆಕಾರ್ಡಿಂಗ್ ಪ್ರಾರಂಭಿಸಿ 🚀" },
  "welcome_trySubtitle": { "message": "ಏನನ್ನು ಕ್ಯಾಪ್ಚರ್ ಮಾಡಬೇಕು ಎಂದು ಆಯ್ಕೆಮಾಡಿ ರೆಕಾರ್ಡಿಂಗ್ ಪ್ರಾರಂಭಿಸಿ—ನೀವು ನಿಲ್ಲಿಸಿದಾಗ ಸ್ಟುಡಿಯೋ ತೆರೆಯುತ್ತದೆ." },
